# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_LLM_MODEL=models/gemini-1.5-flash

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=interview-rag

# Firebase (Wait! Admin SDK can use a JSON credentials file or application default credentials)
# Set this to the absolute path of your downloaded firebase-adminsdk.json file
GOOGLE_APPLICATION_CREDENTIALS=./firebase-credentials.json
# Or specify project ID if needed
FIREBASE_PROJECT_ID=your-firebase-project-id

# Application
DATA_DIR=./data
FRONTEND_URL=http://localhost:5173

# RAG Settings
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=50
TOP_K=5
